# OLT NOC Manager System Environment Config

# Database Config
POSTGRES_USER=olt_admin
POSTGRES_PASSWORD=olt_admin_pass_123
POSTGRES_DB=olt_noc_db
DATABASE_URL=postgresql+asyncpg://olt_admin:olt_admin_pass_123@db:5432/olt_noc_db

# Redis Config
REDIS_URL=redis://redis:6379/0

# Security (JWT and AES Encryption)
JWT_SECRET=super_secret_jwt_key_noc_2026_change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 32-byte key for AES-256 (in hex or plain text, exactly 32 chars)
ENCRYPTION_KEY=noc_manager_super_key_32_bytes_

# Celery Broker / Backend
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# System Polling Intervals (in seconds)
FAST_POLL_INTERVAL=30
METRIC_POLL_INTERVAL=120
INVENTORY_SYNC_INTERVAL=600
